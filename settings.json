{
  "show_completions_on_input": true,
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": false,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": true,
  },
  "close_on_file_delete": true,
  "search": {
    "center_on_match": true,
  },
  "use_smartcase_search": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": false,
  },
  "tab_size": 2,
  "sticky_scroll": {
    "enabled": true,
  },
  "auto_update": false,
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "VSCode",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "ui_font_family": "FiraCode Nerd Font",
  "buffer_font_family": "FiraCode Nerd Font",
  "theme": {
    "mode": "system",
    "light": "Tokyo Night",
    "dark": "Tokyo Night",
  },
  "autosave": "on_window_change",
  "tab_bar": {
    "show": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "shell": {
      "program": "fish",
    },
  },
  // Turn off telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
    "hunk_style": "staged_hollow",
  },
  "git_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "project_panel": {
    "hide_root": true,
    "dock": "right",
    "git_status": true,
    "auto_fold_dirs": false,
  },
  // Disable cursor blink
  "cursor_blink": false,
  // Hide the scroll bar
  "scrollbar": {
    "show": "never",
  },
  // Prevent the buffer from scrolling beyond the last line
  "scroll_beyond_last_line": "off",
  // Allow the cursor to reach the edges of the screen
  "vim_mode": true,
  "vertical_scroll_margin": 8,
  // Use relative line numbers
  "relative_line_numbers": "wrapped",
  "vim": {
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "languages": {
    "PHP": {
      "language_servers": [
        "phpactor"
      ]
    }
  }
}
