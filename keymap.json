[
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // mini.ai plugin behavior
      "q": "vim::MiniQuotes",
      "b": "vim::MiniBrackets",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space e": "pane::RevealInProjectPanel",
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f g": "workspace::NewSearch",
      "space f s": "outline::Toggle",
      "space f b": "tab_switcher::ToggleAll",
      "space f p": "projects::OpenRecent",
      "space g g": "git_panel::Toggle",
      "space g d": "git::Diff",
      "space t a": "agent::Toggle",
      "space t o": "outline_panel::Toggle",
      "space t d": "debug_panel::Toggle",
      "space t r": "vim::ToggleRegistersView",
      "space s d": "diagnostics::Deploy",
      "space s f d": "diagnostics::DeployCurrentFile",
      "ctrl-x": "workspace::ToggleAllDocks",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "alt-h": "editor::MoveLeft",
      "alt-l": "editor::MoveRight",
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "shift-y": [
        "workspace::SendKeystrokes",
        "y $"
      ],
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    }
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
      "shift-x": "vim::Exchange",
    }
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // work when no editor exists.
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "space e": "workspace::ToggleRightDock",
      "ctrl-x": "workspace::ToggleAllDocks",
    },
  },
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-c": "editor::Copy",
      "ctrl-x": "editor::Cut",
      "ctrl-v": "editor::Paste",
      "ctrl-z": "editor::Undo",
      "ctrl-a": "editor::SelectAll",
      "ctrl-o": "workspace::Open",
      "ctrl-f": "buffer_search::Deploy"
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "ctrl-y": "picker::ConfirmCompletion",
    },
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      // Close project panel as project file panel on the right
      "q": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "tab": null
    }
  },
  {
    "context": "(Editor && edit_prediction_conflict)",
    "bindings": {
      "alt-y": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "alt-l": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "(Editor && edit_prediction_conflict)",
    "bindings": {
      "alt-l": null
    }
  },
]
